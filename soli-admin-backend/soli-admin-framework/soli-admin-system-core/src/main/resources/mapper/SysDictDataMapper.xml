<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.soli.system.core.mapper.SysDictDataMapper">

    <resultMap id="SysDictDataResultMap" type="com.soli.system.core.service.impl.sysdictdata.SysDictDataEntity">
        <id property="id" column="id"/>
        <result property="dictTypeId" column="dict_type_id"/>
        <result property="label" column="label"/>
        <result property="value" column="value"/>
        <result property="sort" column="sort"/>
        <result property="cssClass" column="css_class"/>
        <result property="listClass" column="list_class"/>
        <result property="isDefault" column="is_default"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="note" column="note"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, dict_type_id, label, value, sort, css_class, list_class, is_default, status, create_by, create_time, update_by, update_time, note
    </sql>

    <insert id="insert" parameterType="com.soli.system.core.service.impl.sysdictdata.SysDictDataEntity">
        insert into sys_dict_data (
            id, dict_type_id, label, value, sort, css_class, list_class, is_default, status, create_by, create_time, update_by, update_time, note
        ) values (
            #{id}, #{dictTypeId}, #{label}, #{value}, #{sort}, #{cssClass}, #{listClass}, #{isDefault}, #{status}, #{createBy}, #{createTime}, #{updateBy}, #{updateTime}, #{note}
        )
    </insert>

    <update id="update" parameterType="com.soli.system.core.service.impl.sysdictdata.SysDictDataEntity">
        update sys_dict_data
        <set>
            <if test="dictTypeId != null">dict_type_id = #{dictTypeId},</if>
            <if test="label != null">label = #{label},</if>
            <if test="value != null">value = #{value},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="cssClass != null">css_class = #{cssClass},</if>
            <if test="listClass != null">list_class = #{listClass},</if>
            <if test="isDefault != null">is_default = #{isDefault},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="note != null">note = #{note},</if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById">
        delete from sys_dict_data where id = #{id}
    </delete>

    <delete id="deleteByDictTypeId">
        delete from sys_dict_data where dict_type_id = #{dictTypeId}
    </delete>

    <update id="clearDefaultByDictTypeId">
        update sys_dict_data
        set is_default = 'N'
        where dict_type_id = #{dictTypeId}
          and is_default = 'Y'
        <if test="excludeId != null">
          and id != #{excludeId}
        </if>
    </update>

    <select id="select" resultMap="SysDictDataResultMap">
        select <include refid="Base_Column_List"/>
        from sys_dict_data
        <where>
            <if test="dictTypeId != null">
                and dict_type_id = #{dictTypeId}
            </if>
            <if test="label != null and label != ''">
                and label like concat('%', #{label}, '%')
            </if>
            <if test="value != null and value != ''">
                and value like concat('%', #{value}, '%')
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by sort asc, id desc
    </select>

    <select id="selectById" resultMap="SysDictDataResultMap">
        select <include refid="Base_Column_List"/>
        from sys_dict_data
        where id = #{id}
    </select>

</mapper>