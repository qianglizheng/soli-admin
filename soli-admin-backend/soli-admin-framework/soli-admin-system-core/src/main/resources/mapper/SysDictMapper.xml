<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.soli.system.core.mapper.SysDictMapper">

    <resultMap id="SysDictResultMap" type="com.soli.system.core.service.impl.sysdict.SysDictEntity">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="type" column="type"/>
        <result property="status" column="status" javaType="com.soli.common.api.enums.NormalDisableStatusEnum" typeHandler="com.soli.common.core.mybatis.handler.DbEnumTypeHandler"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="note" column="note"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, name, type, status, create_by, create_time, update_by, update_time, note
    </sql>

    <insert id="insert" parameterType="com.soli.system.core.service.impl.sysdict.SysDictEntity">
        insert into sys_dict_type (
            id, name, type, status, create_by, create_time, update_by, update_time, note
        ) values (
            #{id}, #{name}, #{type}, #{status, typeHandler=com.soli.common.core.mybatis.handler.DbEnumTypeHandler}, #{createBy}, #{createTime}, #{updateBy}, #{updateTime}, #{note}
        )
    </insert>

    <update id="update" parameterType="com.soli.system.core.service.impl.sysdict.SysDictEntity">
        update sys_dict_type
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="type != null">type = #{type},</if>
            <if test="status != null">status = #{status, typeHandler=com.soli.common.core.mybatis.handler.DbEnumTypeHandler},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="note != null">note = #{note},</if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById">
        delete from sys_dict_type where id = #{id}
    </delete>

    <select id="select" resultMap="SysDictResultMap">
        select <include refid="Base_Column_List"/>
        from sys_dict_type
        <where>
            <if test="name != null and name != ''">
                and name like concat('%', #{name}, '%')
            </if>
            <if test="type != null and type != ''">
                and type like concat('%', #{type}, '%')
            </if>
            <if test="status != null">
                and status = #{status, typeHandler=com.soli.common.core.mybatis.handler.DbEnumTypeHandler}
            </if>
        </where>
        order by create_time desc, id desc
    </select>

    <select id="selectById" resultMap="SysDictResultMap">
        select <include refid="Base_Column_List"/>
        from sys_dict_type
        where id = #{id}
    </select>

    <select id="selectByType" resultMap="SysDictResultMap">
        select <include refid="Base_Column_List"/>
        from sys_dict_type
        where type = #{type}
        limit 1
    </select>

</mapper>
