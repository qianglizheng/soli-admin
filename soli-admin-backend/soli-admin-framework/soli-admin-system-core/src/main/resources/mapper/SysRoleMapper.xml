<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.soli.system.core.mapper.SysRoleMapper">

    <!-- 用户结果映射 -->
    <resultMap id="SysRoleResultMap" type="com.soli.system.core.service.impl.sysrole.SysRoleEntity">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="code" column="code"/>
        <result property="sort" column="sort"/>
        <result property="dataScope" column="data_scope"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="note" column="note"/>
    </resultMap>

    <!-- 基础字段 -->
    <sql id="Base_Column_List">
        id, name, code, sort, data_scope, status, create_by, create_time, update_by, update_time, note
    </sql>

    <!-- 根据ID查询 -->
    <select id="selectByUserId" resultMap="SysRoleResultMap">
        select <include refid="Base_Column_List"/> from sys_role r inner join sys_user_role ur on r.id = ur.role_id where ur.user_id = #{userId}
    </select>

    <select id="select" resultMap="SysRoleResultMap">
        select <include refid="Base_Column_List"/> from sys_role
    </select>

</mapper>