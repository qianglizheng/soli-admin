<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.soli.system.core.mapper.SysRoleMapper">

    <!-- 用户结果映射 -->
    <resultMap id="SysRoleResultMap" type="com.soli.system.core.service.impl.sysrole.SysRoleEntity">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="code" column="code"/>
        <result property="sort" column="sort"/>
        <result property="dataScope" column="data_scope"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="note" column="note"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, name, code, sort, data_scope, status, create_by, create_time, update_by, update_time, note
    </sql>

    <insert id="insert" parameterType="com.soli.system.core.service.impl.sysrole.SysRoleEntity">
        insert into sys_role (
            id, name, code, sort, data_scope, status, create_by, create_time, update_by, update_time, note
        ) values (
            #{id}, #{name}, #{code}, #{sort}, #{dataScope}, #{status}, #{createBy}, #{createTime}, #{updateBy}, #{updateTime}, #{note}
        )
    </insert>

    <update id="update" parameterType="com.soli.system.core.service.impl.sysrole.SysRoleEntity">
        update sys_role
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="code != null">code = #{code},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="dataScope != null">data_scope = #{dataScope},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="note != null">note = #{note},</if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById">
        delete from sys_role where id = #{id}
    </delete>

    <select id="selectByUserId" resultMap="SysRoleResultMap">
        select <include refid="Base_Column_List"/> from sys_role r inner join sys_user_role ur on r.id = ur.role_id where ur.user_id = #{userId}
    </select>

    <select id="select" resultMap="SysRoleResultMap">
        select <include refid="Base_Column_List"/>
        from sys_role
        <where>
            <if test="roleName != null and roleName != ''">
                and name like concat('%', #{roleName}, '%')
            </if>
            <if test="roleKey != null and roleKey != ''">
                and code like concat('%', #{roleKey}, '%')
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by sort asc, id desc
    </select>

    <select id="selectById" resultMap="SysRoleResultMap">
        select <include refid="Base_Column_List"/>
        from sys_role
        where id = #{id}
    </select>

    <select id="selectAllEnabled" resultMap="SysRoleResultMap">
        select <include refid="Base_Column_List"/>
        from sys_role
        where status = '0'
        order by sort asc, id desc
    </select>

</mapper>